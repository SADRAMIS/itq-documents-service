<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.19.xsd">

    <changeSet id="004-create-document-history-table" author="itq">
        <createTable tableName="document_history">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="pk_document_history"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_history_document" 
                             referencedTableName="documents" referencedColumnNames="id"/>
            </column>
            <column name="initiator" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="action_time" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-history-index" author="itq">
        <createIndex indexName="idx_document_history_document_id"
                     tableName="document_history">
            <column name="document_id"/>
        </createIndex>
        <createIndex indexName="idx_document_history_action_time"
                     tableName="document_history">
            <column name="action_time"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

