<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog">
    <changeSet id="003-approval-registry" author="itq">
        <createTable tableName="approval_registry">
            <column name="document_id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="pk_approval_registry"/>
            </column>
            <column name="approved_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="approver_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_approval_registry_approved_at"
                     tableName="approval_registry">
            <column name="approved_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
